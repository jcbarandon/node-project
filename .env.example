# Copy this file to .env and fill in real values. Do NOT commit .env.

# Port the server listens on (hosting platforms usually set this automatically).
PORT=5000

# Secret used to sign JWTs. Use a long random string in production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me

# Postgres connection string.
DATABASE_URL=postgres://user:password@localhost:5432/node_project

# Set to "true" when connecting to managed Postgres that requires SSL
# (e.g. a Render external database URL). Leave unset for local Postgres.
DATABASE_SSL=false
